{
  "name": "retailcortex",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.3.0",
  "scripts": {
    "dev": "pnpm_config_verify_deps_before_run='' turbo dev",
    "dev:frontend": "turbo dev --filter=frontend",
    "dev:backend": "turbo dev --filter=backend",
    "dev:app": "turbo dev --filter=app",
    "build": "turbo build",
    "lint": "biome lint app/src frontend/src",
    "format": "biome format --write app/src frontend/src",
    "check": "biome check --write app/src frontend/src"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "turbo": "^2"
  }
}
